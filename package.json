{
  "name": "minimal-harness",
  "version": "0.1.0",
  "description": "A lean, framework-agnostic Agent Harness for local LLMs (Ollama-first) — prompt-based tool calling, zero runtime dependencies.",
  "keywords": [
    "agent",
    "agent-harness",
    "llm",
    "local-llm",
    "ollama",
    "tool-calling",
    "function-calling",
    "rag",
    "structured-output",
    "ai-agents",
    "typescript",
    "zero-dependency"
  ],
  "homepage": "https://github.com/mick-gsk/minimal-harness#readme",
  "bugs": {
    "url": "https://github.com/mick-gsk/minimal-harness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mick-gsk/minimal-harness.git"
  },
  "license": "MIT",
  "author": "Mick G. (https://github.com/mick-gsk)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src examples",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.bench.json",
    "typecheck:company": "tsc --noEmit -p company/tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "bench": "tsx bench/runner.ts",
    "bench:probe": "npx tsx bench/probe.ts",
    "bench:ab": "npx tsx bench/ab-experiment.ts",
    "bench:bfcl": "npx tsx bench/bfcl-experiment.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.0.0",
    "@types/node": "^24.13.3",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {}
}
